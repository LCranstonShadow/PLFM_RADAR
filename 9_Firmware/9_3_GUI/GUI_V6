                                packet_length = self.get_packet_length(packet)
                                if packet_length > 0:
                                    buffer = buffer[packet_length:]
                                self.received_packets += 1
                            else:
                                # No valid packet found, shift buffer
                                if len(buffer) > 4:
                                    buffer = buffer[1:]
                                else:
                                    break
                                
                except Exception as e:
                    logging.error(f"Error processing radar data: {e}")
                    time.sleep(0.1)
            else:
                time.sleep(0.1)
    
