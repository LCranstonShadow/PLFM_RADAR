                    # Read from FT601 (supports larger transfers)
                    data = self.ft601_interface.read_data(4096)
                    if data:
                        buffer.extend(data)
                        
                        # Process packets (32-bit aligned)
                        while len(buffer) >= 8:  # Minimum packet size
